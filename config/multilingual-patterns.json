  "seo_considerations": {
    "es": {
      "meta_title_max_chars": 60,
      "meta_description_max_chars": 155,
      "keyword_research_notes": "Consider Spain vs LatAm search terms. LatAm has 5x the search volume for most topics. Use neutral Spanish when targeting both."
    },
    "fr": {
      "meta_title_max_chars": 60,
      "meta_description_max_chars": 155,
      "keyword_research_notes": "France vs Quebec: different vocabulary (ordinateur vs ordi). French text is typically 15-20% longer than English."
    },
    "de": {
      "meta_title_max_chars": 60,
      "meta_description_max_chars": 155,
      "keyword_research_notes": "Compound words are common and often used as search terms (e.g., Suchmaschinenoptimierung). German text is typically 20-30% longer than English; may need to shorten meta tags."
    },
    "pt": {
      "meta_title_max_chars": 60,
      "meta_description_max_chars": 155,
      "keyword_research_notes": "Brazil vs Portugal: significant vocabulary differences. Brazilian Portuguese has ~10x the search volume. Use pt-br by default unless targeting Portugal specifically."
    },
    "it": {
      "meta_title_max_chars": 60,
      "meta_description_max_chars": 155,
      "keyword_research_notes": "Italian text tends to be 10-15% longer than English. Watch meta tag length."
    },
    "nl": {
      "meta_title_max_chars": 60,
      "meta_description_max_chars": 155,
      "keyword_research_notes": "Small market but high-value. Consider Belgium (Flemish) vs Netherlands vocabulary."
    },
    "ja": {
      "meta_title_max_chars": 32,
      "meta_description_max_chars": 120,
      "keyword_research_notes": "Mix of katakana loanwords (AI) and native terms (jinkou chinou). Shorter character limits due to wider characters. Full-width vs half-width matters."
    },
    "zh": {
      "meta_title_max_chars": 30,
      "meta_description_max_chars": 120,
      "keyword_research_notes": "Simplified for mainland China (Baidu SEO differs from Google). Traditional for Taiwan/HK. Shorter limits due to character width."
    },
    "ko": {
      "meta_title_max_chars": 32,
      "meta_description_max_chars": 120,
      "keyword_research_notes": "Mix of Korean and English terms common in tech/business. Naver SEO differs from Google SEO for Korean market."
    },
    "ar": {
      "meta_title_max_chars": 60,
      "meta_description_max_chars": 155,
      "keyword_research_notes": "Modern Standard Arabic for broad reach. Dialectal terms rarely searched. RTL meta tags display correctly in most search engines."
    },
    "hi": {
      "meta_title_max_chars": 60,
      "meta_description_max_chars": 155,
      "keyword_research_notes": "Many Indian users search in English or Hinglish. Pure Hindi keywords have lower volume but higher intent. Devanagari script supported by Google."
    },
    "ru": {
      "meta_title_max_chars": 60,
      "meta_description_max_chars": 155,
      "keyword_research_notes": "Yandex SEO differs from Google. Russian text similar length to English. Cyrillic indexing works well on both engines."
    },
    "pl": {
      "meta_title_max_chars": 60,
      "meta_description_max_chars": 155,
      "keyword_research_notes": "Polish inflection means keywords have multiple word forms. Target the nominative form primarily."
    },
    "tr": {
      "meta_title_max_chars": 60,
      "meta_description_max_chars": 155,
      "keyword_research_notes": "Turkish agglutination creates long compound words. Target root forms in keywords. Growing digital market."
    },
    "vi": {
      "meta_title_max_chars": 60,
      "meta_description_max_chars": 155,
      "keyword_research_notes": "Vietnamese uses diacritics that must be preserved in keywords. Search behavior increasingly in Vietnamese rather than English."
    }
  },
