{
  "_description": "ContentForge Social Platform Specifications — Character limits, hashtag norms, voice guidelines, image specs, best posting times, and supported post types per platform. Used by the Social Adapter Agent (10-social-adapter) and cf-social-adapt skill.",
  "linkedin": {
    "character_limit": 3000,
    "ideal_length": {
      "min": 800,
      "max": 1500,
      "sweet_spot": 1200
    },
    "hashtags": {
      "count_min": 3,
      "count_max": 5,
      "style": "professional",
      "placement": "end_of_post",
      "notes": "Use industry-specific terms. Avoid overly generic hashtags. CamelCase for readability."
    },
    "voice": {
      "tone": "professional",
      "formality": "high",
      "personality": ["insightful", "authoritative", "data-backed"],
      "avoid": ["slang", "excessive emojis", "clickbait phrasing", "all caps"],
      "notes": "Write like a knowledgeable peer, not a press release. Conversational authority."
    },
    "format": {
      "line_breaks": true,
      "line_break_style": "double_newline_between_paragraphs",
      "list_style": "-- (em dash prefix)",
      "emojis": "minimal_or_none",
      "link_placement": "end_of_post_or_first_comment",
      "truncation_point": 210,
      "truncation_note": "LinkedIn shows ~210 characters before 'see more'. Hook must be in first 2 lines."
    },
    "image_specs": {
      "feed": {
        "width": 1200,
        "height": 627,
        "ratio": "1.91:1",
        "formats": ["PNG", "JPG", "GIF"],
        "max_size_mb": 10
      },
      "carousel": {
        "width": 1080,
        "height": 1080,
        "ratio": "1:1",
        "max_slides": 20,
        "formats": ["PDF", "PNG", "JPG"]
      }
    },
    "best_times": [
      {"day": "Tuesday", "times": ["08:00", "10:00"]},
      {"day": "Wednesday", "times": ["09:00", "12:00"]},
      {"day": "Thursday", "times": ["08:00", "10:00"]}
    ],
    "worst_times": ["weekends", "after 17:00"],
    "post_types": [
      "thought_leadership",
      "data_analysis",
      "how_to",
      "industry_commentary",
      "case_study",
      "carousel_document",
      "poll"
    ],
    "algorithm_notes": "External links may reduce reach. Consider putting link in first comment. Native documents (carousels) get higher distribution."
  },
